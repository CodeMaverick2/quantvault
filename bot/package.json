{
  "name": "quantvault-bot",
  "version": "1.0.0",
  "description": "QuantVault adaptive delta-neutral keeper bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@drift-labs/sdk": "^2.100.0",
    "@solana/web3.js": "^1.95.0",
    "@coral-xyz/anchor": "^0.31.1",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "prom-client": "^15.1.3",
    "winston": "^3.17.0",
    "yaml": "^2.7.0",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts"],
    "coverageDirectory": "coverage"
  }
}
